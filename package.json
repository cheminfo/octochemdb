{
  "name": "octochemdb",
  "version": "1.0.0",
  "description": "OctoChemDB — chemistry database backend (MongoDB-backed Fastify service).",
  "type": "module",
  "private": true,
  "author": "Michaël Zasso",
  "license": "MIT",
  "homepage": "https://github.com/cheminfo/octochemdb#readme",
  "bugs": {
    "url": "https://github.com/cheminfo/octochemdb/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cheminfo/octochemdb.git"
  },
  "scripts": {
    "cron": "DEBUG=* node -r dotenv/config src/sync/cron",
    "crontest": "DEBUG=* TEST=true node -r dotenv/config src/sync/cron",
    "dev": "DEBUG=* LOGGER_PRETTY_PRINT=true node --watch -r dotenv/config src/server/index.js",
    "eslint": "eslint src",
    "eslint-fix": "eslint src --fix",
    "prettier": "prettier --check src",
    "prettier-write": "prettier --write src",
    "start": "DEBUG=* node -r dotenv/config src/server/index.js",
    "test": "npm run test-only && npm run eslint && npm run prettier",
    "test-only": "vitest run --coverage --test-timeout=80000 --no-file-parallelism"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "arraybuffer-xml-parser": "^2.2.0",
    "bson-iterator": "^1.0.0",
    "camelcase": "^9.0.0",
    "camelcase-keys": "^10.0.2",
    "csv-parser": "^3.2.0",
    "debug": "^4.4.3",
    "delay": "^7.0.0",
    "dotenv": "^17.4.2",
    "fast-xml-parser": "^5.7.3",
    "fastify": "^5.8.5",
    "filelist-utils": "^1.11.3",
    "fs-extra": "^11.3.4",
    "lodash": "^4.18.1",
    "lodash.escaperegexp": "^4.1.2",
    "mass-fragmentation": "^1.12.1",
    "mass-tools": "^2.3.7",
    "md5": "^2.3.0",
    "mf-parser": "^3.9.1",
    "mkdirp": "^3.0.1",
    "ml-spectra-processing": "^14.28.1",
    "ml-stat": "^1.3.3",
    "mongodb": "^7.2.0",
    "most-common-words-by-language": "^3.0.14",
    "msp-parser": "^0.0.1",
    "node-exec-promise": "^1.0.2",
    "node-fetch": "^3.3.2",
    "node-stream-zip": "^1.15.0",
    "openchemlib": "^9.22.1",
    "openchemlib-utils": "^8.15.0",
    "papaparse": "^5.5.3",
    "piscina": "^5.1.4",
    "sdf-parser": "^8.0.0",
    "split2": "^4.2.0",
    "stream-json": "^2.1.0",
    "unzipper": "^0.12.3",
    "xml-flow": "^1.0.4",
    "xml2json": "^0.12.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "benchmark": "^2.1.4",
    "eslint": "^9.39.4",
    "eslint-config-cheminfo": "^18.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "vitest": "^4.1.5"
  }
}
