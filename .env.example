### Parameters
MONGODB_URL=mongodb://localhost:27017
MONGO_DB_NAME=octochemdb

### Docker resource limits (used by compose.yaml)
# Max CPUs available to the import container.
# Must be <= the host's CPU count (docker compose up will fail otherwise).
IMPORT_CPUS=6

### Sources
# Only sources read from process.env are listed here. The other dump URLs are
# hard-coded in each plugin's sync module.
ORIGINAL_DATA_PATH=data/originalData/
COCONUT_SOURCE=https://coconut.naturalproducts.net/download/mongo
OCL_CACHE=https://ocl-cache.cheminfo.org/v1/fromIDCode?idCode=

### Plugins
# Port the Fastify server listens on.
PORT=11015
DEBUG_THROTTLING=10000
# Minimum severity of debug records persisted to MongoDB (trace|info|warn|error|fatal).
DEBUG_LEVEL=trace
# Minimum severity forwarded to Telegram.
TELEGRAM_DEBUG_LEVEL=fatal
# Suppress the dotenv "injected env (n) from .env // tip: ..." banner on every load.
DOTENV_CONFIG_QUIET=true
PLUGINS=gnps
#EXCLUDEPLUGINS=pubmeds
TELEGRAM_BOT_ID=
TELEGRAM_CHAT_ID=

### Cloudflare Tunnel (only used by compose.example.cloudflared.yaml)
# Token obtained from the Cloudflare dashboard when creating a tunnel.
TUNNEL_TOKEN=

### Update intervals in days
TAXONOMY_UPDATE_INTERVAL=7
PATENT_UPDATE_INTERVAL=7
PUBMED_UPDATE_INTERVAL=1
PUBCHEM_UPDATE_INTERVAL=3
GNPS_UPDATE_INTERVAL=3
BIOASSAY_UPDATE_INTERVAL=3
BIOASSAYPUBCHEM_UPDATE_INTERVAL=3
CMAUP_UPDATE_INTERVAL=3
COCONUT_UPDATE_INTERVAL=3
NPASS_UPDATE_INTERVAL=3
NPATLAS_UPDATE_INTERVAL=3
LOTUS_UPDATE_INTERVAL=3
LCCS_UPDATE_INTERVAL=3
MASSBANK_UPDATE_INTERVAL=3
COMPOUND_PATENTS_UPDATE_INTERVAL=7
TITLECOMPOUNDS_UPDATE_INTERVAL=3
